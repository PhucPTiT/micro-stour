{
    "name": "micro-stour",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "create:app": "node ./scripts/create-app.mjs",
        "dev": "node ./scripts/run-workspace-apps.mjs",
        "dev:shell-template": "pnpm --filter shell-base dev",
        "dev:module-template": "pnpm --filter module-base dev",
        "dev:integration-template": "concurrently -k -n shell,module \"pnpm --filter shell-base dev\" \"pnpm --filter module-base dev:federation\"",
        "lint": "biome check . --write",
        "lint:check": "biome check . --diagnostic-level=error",
        "format": "biome format .",
        "typecheck": "turbo typecheck --filter=!shell-base --filter=!module-base",
        "build": "pnpm lint && pnpm typecheck && turbo build --filter=!shell-base --filter=!module-base"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "concurrently": "^9.2.1",
        "turbo": "^2.8.17",
        "typescript": "5.9.3"
    },
    "packageManager": "pnpm@9.15.9",
    "engines": {
        "node": ">=20"
    }
}
