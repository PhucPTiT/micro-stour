{
  "name": "micro-stour",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm run dev:integration",
    "dev:shell": "pnpm --filter shell-base dev",
    "dev:module": "pnpm --filter module dev",
    "dev:integration": "concurrently -k -n shell,module \"pnpm --filter shell-base dev\" \"pnpm --filter module dev:federation\"",
    "lint": "biome check .",
    "format": "biome format .",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "concurrently": "^9.2.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
